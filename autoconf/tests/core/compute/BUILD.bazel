load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("//autoconf:checks.bzl", "checks")
load("//autoconf:package_info.bzl", "package_info")
load("//autoconf/tests:diff_test.bzl", "diff_test")

package_info(
    name = "package",
    package_name = "test_compute",
    package_version = "1.0.0",
)

autoconf(
    name = "autoconf",
    checks = [
        checks.AC_COMPUTE_INT("TWO", "1 + 1"),
        checks.AC_COMPUTE_INT("ANSWER", "42"),
        checks.AC_COMPUTE_INT("HUNDRED", "100"),
        checks.AC_COMPUTE_INT("SEARCH_BEGIN", "-1024"),
        checks.AC_COMPUTE_INT("SEARCH_END", "1024"),
    ],
    deps = [":package"],
)

autoconf_hdr(
    name = "config",
    out = "config.h",
    template = "config.h.in",
    deps = [":autoconf"],
)

# Absolute limits of the binary search range [-1024, 1024]
_RANGE_BOUNDARIES = [
    -1024,
    1024,
]

# One step inside each boundary to catch off-by-one at the edges
_NEAR_BOUNDARIES = [
    -1023,
    1023,
]

# Midpoint region where positive/negative sign flips
_ZERO_REGION = [
    -1,
    0,
    1,
]

# Binary search pivot points (powers of 2, positive and negative)
_POWERS_OF_2 = [
    2,
    4,
    8,
    16,
    32,
    64,
    128,
    256,
    512,
    -2,
    -4,
    -8,
    -16,
    -32,
    -64,
    -128,
    -256,
    -512,
]

# Fencepost values just below each pivot (2^n - 1)
_POWERS_OF_2_MINUS_1 = [
    3,
    7,
    15,
    31,
    63,
    127,
    255,
    511,
    1023,
    -3,
    -7,
    -15,
    -31,
    -63,
    -127,
    -255,
    -511,
    -1023,
]

# Fencepost values just above each pivot (2^n + 1)
_POWERS_OF_2_PLUS_1 = [
    3,
    5,
    9,
    17,
    33,
    65,
    129,
    257,
    513,
    -3,
    -5,
    -9,
    -17,
    -33,
    -65,
    -129,
    -257,
    -513,
]

# Arbitrary non-power-of-2 values for general correctness
_ARBITRARY = [
    42,
    -42,
    100,
    -100,
    333,
    -333,
    777,
    -777,
]

MEANINGFUL_VALUES = sorted({v: True for v in (
    _RANGE_BOUNDARIES +
    _NEAR_BOUNDARIES +
    _ZERO_REGION +
    _POWERS_OF_2 +
    _POWERS_OF_2_MINUS_1 +
    _POWERS_OF_2_PLUS_1 +
    _ARBITRARY
)}.keys())

autoconf(
    name = "check_value_autoconf",
    checks = [
        checks.AC_COMPUTE_INT(
            "DEFINE_{}".format(i).replace("-", "_"),
            str(i),
        )
        for i in MEANINGFUL_VALUES
    ],
)

write_file(
    name = "test_all_values_c",
    out = "test_all_values.c",
    content = """\
#undef NDEBUG
#include <assert.h>
#include "template.h"
int main(){{
{}
return 0;
}}
""".format("\n".join([
        """assert(DEFINE_{} == {});""".format(
            str(i).replace("-", "_"),
            str(i),
        )
        for i in MEANINGFUL_VALUES
    ])).splitlines(),
)

write_file(
    name = "template_h_in",
    out = "template.h.in",
    content = ["#undef DEFINE_{}".format(i).replace("-", "_") for i in MEANINGFUL_VALUES] + [""],
)

autoconf_hdr(
    name = "template_h",
    out = "template.h",
    template = ":template.h.in",
    deps = ["check_value_autoconf"],
)

cc_test(
    name = "test_all_values",
    srcs = [
        "template.h",
        ":test_all_values.c",
    ],
)

diff_test(
    name = "diff_test",
    file1 = "golden_config.h.in",
    file2 = ":config.h",
)

cc_test(
    name = "test_compute",
    srcs = [
        "test_compute.c",
        ":config.h",
    ],
)

sh_binary(
    name = "test_failure",
    srcs = ["test_failure.sh"],
)
