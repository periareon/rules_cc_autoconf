load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("@rules_shell//shell:sh_binary.bzl", "sh_binary")
load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("//autoconf:checks.bzl", "checks")
load("//autoconf:package_info.bzl", "package_info")
load("//autoconf/tests:diff_test.bzl", "diff_test")
load("defs.bzl", "RANGE_BEGIN", "RANGE_END", "gen_template_and_src")

package_info(
    name = "package",
    package_name = "test_compute",
    package_version = "1.0.0",
)

autoconf(
    name = "autoconf",
    checks = [
        checks.AC_COMPUTE_INT("TWO", "1 + 1"),
        checks.AC_COMPUTE_INT("ANSWER", "42"),
        checks.AC_COMPUTE_INT("HUNDRED", "100"),
        checks.AC_COMPUTE_INT("SEARCH_BEGIN", "-1024"),
        checks.AC_COMPUTE_INT("SEARCH_END", "1024"),
    ],
    deps = [":package"],
)

autoconf_hdr(
    name = "config",
    out = "config.h",
    template = "config.h.in",
    deps = [":autoconf"],
)

autoconf(
    name = "check_value_autoconf",
    checks = [
        checks.AC_COMPUTE_INT(
            "DEFINE_{}".format(i).replace("-", "_"),
            str(i),
        )
        for i in range(RANGE_BEGIN, RANGE_END, 1)
    ],
)

gen_template_and_src(name = "template_and_src")

filegroup(
    name = "template",
    srcs = [":template_and_src"],
    output_group = "template",
)

autoconf_hdr(
    name = "template_h",
    out = "template.h",
    template = ":template",
    deps = ["check_value_autoconf"],
)

filegroup(
    name = "c",
    srcs = [":template_and_src"],
    output_group = "c",
)

cc_test(
    name = "test_all_values",
    srcs = [
        "template.h",
        ":c",
    ],
)

diff_test(
    name = "diff_test",
    file1 = "golden_config.h.in",
    file2 = ":config.h",
)

cc_test(
    name = "test_compute",
    srcs = [
        "test_compute.c",
        ":config.h",
    ],
)

sh_binary(
    name = "test_failure",
    srcs = ["test_failure.sh"],
)
