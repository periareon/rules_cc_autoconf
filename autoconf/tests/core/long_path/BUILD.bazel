load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("//autoconf:checks.bzl", "checks")
load("//autoconf:package_info.bzl", "package_info")
load("//autoconf/tests:diff_test.bzl", "diff_test")

# Regression test for Windows MAX_PATH (260 character) limit.
#
# Bazel constructs output paths like:
#   <execroot>/bazel-out/<config>/bin/<package>/<target>/<check>.result.cache.json-0.params
#
# With long check names (common in gnulib), this path can exceed 260 characters
# on Windows, causing std::ifstream to fail. The file_util.h open_ifstream /
# open_ofstream wrappers apply the \\?\ extended-length path prefix to bypass
# this limit.
#
# This test uses an intentionally absurd cache variable name to guarantee that
# the generated paths exceed MAX_PATH on any Windows build environment.

package_info(
    name = "package",
    package_name = "test_long_path",
    package_version = "1.0.0",
)

autoconf(
    name = "autoconf",
    checks = [
        # The cache variable name here is intentionally very long. When combined
        # with the bazel-out path prefix, config hash, and package path, it
        # produces output paths well over 260 characters on Windows.
        checks.AC_CHECK_FUNC(
            "malloc",
            name = "ac_cv_func_malloc_with_an_intentionally_long_cache_variable_name_to_stress_test_the_windows_maximum_path_length_limit_for_bazel_output_paths_and_params_files",
            define = "HAVE_MALLOC_LONG_PATH_TEST",
        ),
    ],
    deps = [":package"],
)

autoconf_hdr(
    name = "config",
    out = "config.h",
    template = "config.h.in",
    deps = [":autoconf"],
)

diff_test(
    name = "diff_test",
    file1 = "golden_config.h.in",
    file2 = ":config.h",
)

cc_test(
    name = "test_long_path",
    srcs = [
        "test_long_path.c",
        ":config.h",
    ],
)
