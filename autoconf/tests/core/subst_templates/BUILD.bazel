load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("//autoconf:macros.bzl", "macros")
load("//autoconf:package_info.bzl", "package_info")
load("//autoconf/tests:diff_test.bzl", "diff_test")
load("@bazel_skylib//rules:write_file.bzl", "write_file")

package_info(
    name = "package_info",
    package_name = "test_subst_templates",
    package_version = "2.3.4",
)

write_file(
    name = "generated_file_h_in",
    out = "generated_file.h.in",
    content = """\
#define FROM_GENERATED 1
""".splitlines(),
    newline = "unix",
)

autoconf(
    name = "autoconf",
    checks = [
        macros.AC_SUBST("SUBST_VAR"),
        macros.AC_DEFINE("SPECIAL_DEFINE"),
    ],
    deps = [":package_info"],
)

autoconf_hdr(
    name = "config",
    out = "config.h",
    template = "config.h.in",
    deps = [":autoconf"],
    mode = "defines",
)

autoconf_hdr(
    name = "subst",
    out = "subst.h",
    inlines = {
        "/* inline source */": "inlined_file.h.in",
        "/* inline generated */": ":generated_file.h.in",
    },
    template = "subst.h.in",
    deps = [":autoconf"],
    mode = "subst",
)

diff_test(
    name = "subst_diff_test",
    file1 = "golden_subst.h.in",
    file2 = ":subst.h",
)

diff_test(
    name = "config_diff_test",
    file1 = "golden_config.h.in",
    file2 = ":config.h",
)

cc_test(
    name = "test_subst_templates",
    srcs = [
        "test_subst_templates.c",
        ":config.h",
        ":subst.h",
    ],
)
