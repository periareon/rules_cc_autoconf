load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

autoconf(
    name = "config_gen",
    package_name = "test_sizeof",
    out = "config.h",
    checks = [
        macros.AC_CHECK_SIZEOF("char"),
        macros.AC_CHECK_SIZEOF("short"),
        macros.AC_CHECK_SIZEOF("int"),
        macros.AC_CHECK_SIZEOF("long"),
        macros.AC_CHECK_SIZEOF("void*"),
    ],
    package_version = "1.0.0",
    template = "config.h.in",
)

# Note: sizeof values are platform-dependent, so we only run cc_test
cc_test(
    name = "test_sizeof",
    srcs = [
        "test_sizeof.c",
        ":config.h",
    ],
)
