load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("//autoconf:macros.bzl", "macros")
load("//autoconf/private/tests:diff_test.bzl", "diff_test")

# autoconf_hdr works standalone without an autoconf target
# This demonstrates that autoconf_hdr can add its own checks independently
autoconf_hdr(
    name = "config",
    package_name = "test_hdr",
    out = "config.h",
    # Add checks directly in autoconf_hdr (combines defines, headers, and functions)
    checks = [
        # Custom defines (cross-platform friendly)
        macros.AC_DEFINE("CUSTOM_VALUE", "42"),
        macros.AC_DEFINE("ENABLE_FEATURE", "1"),
        # Standard headers (cross-platform friendly - stdio.h and stdlib.h exist everywhere)
        macros.AC_CHECK_HEADER("stdio.h"),
        macros.AC_CHECK_HEADER("stdlib.h"),
        # Standard functions (cross-platform friendly)
        macros.AC_CHECK_FUNC("malloc"),
        macros.AC_CHECK_FUNC("printf"),
    ],
    package_version = "1.0.0",
    template = "config.h.in",
)

diff_test(
    name = "diff_test",
    file1 = "golden_config.h.in",
    file2 = ":config.h",
)

cc_test(
    name = "test_hdr",
    srcs = [
        "test_hdr.c",
        ":config.h",
    ],
)
