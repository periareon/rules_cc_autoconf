load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("//autoconf:autoconf_srcs.bzl", "autoconf_srcs")
load("//autoconf:macros.bzl", "macros")

autoconf(
    name = "autoconf",
    package_name = "test_srcs",
    checks = [
        # Always-on feature.
        macros.AC_DEFINE("HAVE_GOOD_SRC", "1"),
        # Intentionally fails to compile so the check result is unsuccessful.
        macros.AC_TRY_COMPILE(
            code = "#error do not compile",
            define = "HAVE_BAD_SRC",
            language = "c",
        ),
    ],
    package_version = "1.0.0",
)

autoconf_hdr(
    name = "config_h",
    out = "config.h",
    autoconf = ":autoconf",
    template = "config.h.in",
)

autoconf_srcs(
    name = "generated_srcs",
    srcs = {
        "bad/bad.c": "HAVE_BAD_SRC",
        "good/good.c": "HAVE_GOOD_SRC",
    },
    autoconf = ":config_h",
)

cc_test(
    name = "test_srcs",
    srcs = [
        "test_driver.c",
        ":config.h",
        ":generated_srcs",
    ],
)
