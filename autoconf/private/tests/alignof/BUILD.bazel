load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("//autoconf:macros.bzl", "macros")

autoconf(
    name = "autoconf",
    package_name = "test_alignof",
    checks = [
        macros.AC_CHECK_ALIGNOF("char"),
        macros.AC_CHECK_ALIGNOF("int"),
        macros.AC_CHECK_ALIGNOF("double"),
    ],
    package_version = "1.0.0",
)

autoconf_hdr(
    name = "config",
    out = "config.h",
    autoconf = ":autoconf",
    template = "config.h.in",
)

# Note: alignof values are platform-dependent, so we only run cc_test
cc_test(
    name = "test_alignof",
    srcs = [
        "test_alignof.c",
        ":config.h",
    ],
)
