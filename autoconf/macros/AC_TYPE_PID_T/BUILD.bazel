"""AC_TYPE_PID_T - Autoconf builtin macro

Checks if pid_t type is defined.

Defines:
  - pid_t (if not defined, defined to int)
"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:checks.bzl", "checks")

autoconf(
    name = "AC_TYPE_PID_T",
    checks = [
        checks.AC_CHECK_TYPE("pid_t"),
        checks.AC_DEFINE(
            "pid_t",
            "int",
            requires = ["!ac_cv_type_pid_t"],
        ),
    ],
    visibility = ["//visibility:public"],
)
