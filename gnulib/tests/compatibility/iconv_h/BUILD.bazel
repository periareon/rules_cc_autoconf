load("//gnulib/tests/compatibility:gnu_gnulib_diff_test.bzl", "gnu_gnulib_diff_test_suite")

gnu_gnulib_diff_test_suite(
    name = "iconv_h_test",
    bazel_autoconf_target = "//gnulib/m4/iconv_h:with_defaults",
    config_h_in = "config.h.in",
    configure_ac = "configure.ac",
