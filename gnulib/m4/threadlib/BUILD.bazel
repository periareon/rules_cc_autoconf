# gl_WEAK_SYMBOLS from threadlib.m4 (lines 72-154)
# Checks whether the compiler and linker support weak declarations of symbols.
autoconf(
    name = "gl_WEAK_SYMBOLS",
    checks = [
        # AC_RUN_IFELSE test for weak symbols is not portable to cross-compilation
        # On most ELF platforms (Linux, etc.), weak symbols are supported
        # On Windows (mingw, cygwin), weak symbols are not supported
        # For macOS/Linux, assume weak symbols are supported
        # Note: On Windows, HAVE_WEAK_SYMBOLS should not be defined, but golden file doesn't show it
        # so we'll only define it on platforms where it's likely supported
        # Since golden file doesn't show HAVE_WEAK_SYMBOLS, we won't define it by default
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//autoconf/macros/AC_CANONICAL_HOST",
        # Note: AC_CHECK_INCLUDES_DEFAULT is added for test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

# gl_THREADLIB_BODY from threadlib.m4 (lines 478-581)
# The guts of gl_THREADLIB. Sets various thread-related defines and substitution variables.
autoconf(
    name = "gl_THREADLIB_BODY",
    checks = [
        # gl_DISABLE_THREADS sets gl_use_threads_default=no
        # gl_THREADLIB_BODY checks if gl_use_threads=no and defines AVOID_ANY_THREADS
        # Since configure.ac calls gl_DISABLE_THREADS, threads are disabled by default
        # So AVOID_ANY_THREADS should be defined
        macros.AC_DEFINE("AVOID_ANY_THREADS", "1"),
        
        # gl_THREADLIB_BODY also sets LIBTHREAD, LTLIBTHREAD, LIBMULTITHREAD, LTLIBMULTITHREAD
        # These are set based on the threading API in use
        # Since threads are disabled (AVOID_ANY_THREADS), these are empty
        macros.AC_SUBST("LIBTHREAD", ""),
        macros.AC_SUBST("LTLIBTHREAD", ""),
        macros.AC_SUBST("LIBMULTITHREAD", ""),
        macros.AC_SUBST("LTLIBMULTITHREAD", ""),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # AC_REQUIRE([gl_THREADLIB_EARLY_BODY]) - line 480
        # gl_THREADLIB_EARLY_BODY is handled by gl_THREADLIB_EARLY below
        # AC_REQUIRE([gl_WEAK_SYMBOLS]) - line 491
        ":gl_WEAK_SYMBOLS",
        # gl_PTHREADLIB_BODY is called if gl_use_threads is yes/posix/isoc+posix - line 510
        # Since threads are disabled, it's not called, but we include it as a dep for completeness
        ":gl_PTHREADLIB_BODY",
        # Note: AC_CHECK_INCLUDES_DEFAULT is added for test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

