"""https://github.com/coreutils/gnulib/blob/1039a5f2cee3cda1c11f64a5eb3a15b2e87cd2f0/m4/crc.m4"""

load("//autoconf:autoconf_toolchain.bzl", autoconf = "autoconf_cache")

autoconf(
    name = "crc",
    checks = [
        # gl_CRC_SLICE_BY_8 and gl_DISABLE_CRC_SLICE_BY_8 macros from crc.m4
        # handle configuration options for CRC slice-by-8 algorithm.
        # These are configure-time options, not compile-time checks.
    ],
    visibility = ["//visibility:public"],
)
