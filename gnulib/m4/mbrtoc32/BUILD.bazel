"""https://github.com/coreutils/gnulib/blob/635dbdcf501d52d2e42daf6b44261af9ce2dfe38/m4/mbrtoc32.m4"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

# gl_CHECK_FUNC_MBRTOC32 - lines 63-88
# Check for mbrtoc32 declaration and function
autoconf(
    name = "gl_CHECK_FUNC_MBRTOC32",
    checks = [
        # AC_CHECK_DECL([mbrtoc32], ...) - lines 70-75
        # Note: The m4 file includes stdint.h for Haiku, but we'll just use uchar.h
        macros.AC_CHECK_DECL(
            "mbrtoc32",
            define = "ac_cv_have_decl_mbrtoc32",
            headers = ["stdint.h", "uchar.h"],
        ),
        
        # if test $ac_cv_have_decl_mbrtoc32 = yes; then
        #   AC_CACHE_CHECK([for mbrtoc32], [gl_cv_func_mbrtoc32], ...) - lines 76-87
        #   AC_LINK_IFELSE checks for mbrtoc32 function
        # else
        #   gl_cv_func_mbrtoc32=no - line 88
        # fi
        macros.AC_TRY_LINK(
            code = """#include <stdlib.h>
#ifdef __HAIKU__
#include <stdint.h>
#endif
#include <uchar.h>
char32_t c;
int main(void) { return mbrtoc32(&c, "", 1, NULL) == 0; }""",
            define = "gl_cv_func_mbrtoc32",
            language = "c",
            requires = ["ac_cv_have_decl_mbrtoc32"],
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

