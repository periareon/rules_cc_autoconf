        # AC_REQUIRE([gt_LOCALE_FR]) - line 241
        # AC_REQUIRE([gt_LOCALE_ZH_CN]) - line 242
        # AC_REQUIRE([AC_CANONICAL_HOST]) - line 243
        
        # if test $GNULIBHEADERS_OVERRIDE_CHAR32_T = 1 || test $gl_cv_func_mbrtoc32 = no; then
        #   HAVE_WORKING_MBRTOC32=0 - line 244
        # else
