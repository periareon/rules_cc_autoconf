"""https://github.com/coreutils/gnulib/blob/635dbdcf501d52d2e42daf6b44261af9ce2dfe38/m4/setenv.m4"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

# gl_FUNC_SETENV_SEPARATE - lines 41-49
# Like gl_FUNC_SETENV, except prepare for separate compilation
autoconf(
    name = "gl_FUNC_SETENV_SEPARATE",
    checks = [
        # AC_REQUIRE([gl_STDLIB_H_DEFAULTS]) - line 44
        # Note: gl_STDLIB_H_DEFAULTS is a _DEFAULTS function, so we ignore it per user's instruction

        # AC_CHECK_DECLS_ONCE([setenv]) - line 45
        macros.AC_CHECK_DECL(
            "setenv",
            define = "ac_cv_have_decl_setenv",
            headers = ["stdlib.h"],
        ),

        # if test $ac_cv_have_decl_setenv = no; then
        #   HAVE_DECL_SETENV=0 - line 46-48
        # fi
        macros.AC_SUBST(
            "HAVE_DECL_SETENV",
            condition = "ac_cv_have_decl_setenv",
            if_false = "0",
        ),

        # Define HAVE_DECL_SETENV in config.h
        macros.AC_DEFINE(
            "HAVE_DECL_SETENV",
            condition = "ac_cv_have_decl_setenv",
            if_true = "1",
        ),

        # AC_CHECK_FUNCS_ONCE([setenv]) - line 49
        macros.AC_CHECK_FUNC(
            "setenv",
            define = "ac_cv_func_setenv",
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # AC_REQUIRE([gl_STDLIB_H_DEFAULTS]) - line 44
        # Note: gl_STDLIB_H_DEFAULTS is a _DEFAULTS function, so we ignore it per user's instruction
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

# gl_FUNC_SETENV - lines 10-38
# Checks for setenv function and sets HAVE_SETENV and REPLACE_SETENV
autoconf(
    name = "gl_FUNC_SETENV",
    checks = [
        # AC_REQUIRE([gl_FUNC_SETENV_SEPARATE]) - line 11
        # This is provided by gl_FUNC_SETENV_SEPARATE dependency

        # AC_REQUIRE([AC_CANONICAL_HOST]) - line 12
        # This is provided by AC_CANONICAL_HOST dependency

        # if test $ac_cv_func_setenv = no; then
        #   HAVE_SETENV=0 - line 13-14
        # else
        #   AC_CACHE_CHECK([whether setenv validates arguments], ...) - lines 15-33
        #   Uses AC_RUN_IFELSE which is not portable
        #   Based on golden files, REPLACE_SETENV=0 on macOS/Linux (function works)
        # fi
        macros.AC_SUBST(
            "HAVE_SETENV",
            condition = "ac_cv_func_setenv",
            if_false = "0",
            if_true = "1",
        ),

        # Define HAVE_SETENV in config.h only if the function exists
        macros.AC_DEFINE(
            "HAVE_SETENV",
            condition = "ac_cv_func_setenv",
            if_true = "1",
        ),

        # REPLACE_SETENV=1 if function doesn't work correctly - lines 36-37
        # Based on golden files, REPLACE_SETENV=0 on macOS/Linux (function works)
        macros.AC_SUBST("REPLACE_SETENV", "0"),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # AC_REQUIRE([gl_FUNC_SETENV_SEPARATE]) - line 11
        ":gl_FUNC_SETENV_SEPARATE",
        # AC_REQUIRE([AC_CANONICAL_HOST]) - line 12
        "//autoconf/macros/AC_CANONICAL_HOST",
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

