# gl_PREREQ_SETENV - lines 144-151
# Prerequisites of lib/setenv.c
autoconf(
    name = "gl_PREREQ_SETENV",
    checks = [
        # AC_REQUIRE([gl_ENVIRON]) - line 147
        # This is provided by environ dependency

        # AC_CHECK_HEADERS_ONCE([unistd.h]) - line 148
        # Already checked by dependencies

        # AC_CHECK_HEADERS([search.h]) - line 149
        macros.AC_CHECK_HEADER("search.h"),

        # AC_CHECK_DECLS_ONCE([_putenv]) - line 150
        macros.AC_CHECK_DECL(
            "_putenv",
            define = "ac_cv_have_decl__putenv",
            headers = ["stdlib.h"],
        ),

        # Define HAVE_DECL__PUTENV in config.h
        # If not found, define as 0 (not undefined)
        macros.AC_DEFINE(
            "HAVE_DECL__PUTENV",
            condition = "ac_cv_have_decl__putenv",
            if_false = "0",
            if_true = "1",
        ),

        # gl_CHECK_FUNCS_ANDROID([tsearch], [[#include <search.h>]]) - line 151
        # Check for tsearch function
        macros.AC_TRY_LINK(
            code = """\
#include <search.h>
int main(void) {
    (void)tsearch;
    return 0;
}
""",
            define = "ac_cv_func_tsearch",
        ),

        # Define HAVE_TSEARCH in config.h if the function exists
        macros.AC_DEFINE(
            "HAVE_TSEARCH",
            condition = "ac_cv_func_tsearch",
            if_true = "1",
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # AC_REQUIRE([gl_ENVIRON]) - line 147
        "//gnulib/m4/environ",
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

