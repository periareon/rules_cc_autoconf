"""https://github.com/coreutils/gnulib/blob/635dbdcf501d52d2e42daf6b44261af9ce2dfe38/m4/wint_t.m4"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

# Combined gt_TYPE_WINT_T and gl_TYPE_WINT_T_PREREQ
autoconf(
    name = "wint_t",
    checks = [
        # Check for wint_t type
        macros.AC_TRY_COMPILE(
            code = """#include <wchar.h>
wint_t foo = (wchar_t)'\\0';
int main(void) { return 0; }
""",
            define = "HAVE_WINT_T",
            language = "c",
        ),
        # Check whether wint_t is large enough
        macros.AC_TRY_COMPILE(
            code = """#include <wchar.h>
int verify[sizeof (wint_t) < sizeof (int) ? -1 : 1];
int main(void) { return 0; }
""",
            define = "_gl_cv_type_wint_t_large_enough",
            language = "c",
        ),
        macros.AC_SUBST(
            "GNULIBHEADERS_OVERRIDE_WINT_T",
            condition = "_gl_cv_type_wint_t_large_enough",
            if_false = "1",
            if_true = "0",
        ),
        # Check for crtdefs.h (Windows-specific header)
        macros.AC_CHECK_HEADER(
            "crtdefs.h",
            define = "_gl_have_crtdefs_h",
        ),
        macros.AC_SUBST(
            "HAVE_CRTDEFS_H",
            condition = "_gl_have_crtdefs_h",
            if_false = "0",
            if_true = "1",
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

autoconf(
    name = "defaults",
    checks = [],
    visibility = ["//visibility:public"],
)

autoconf(
    name = "with_defaults",
    checks = [],
    visibility = ["//visibility:public"],
    deps = [
        ":defaults",
        ":wint_t",
    ],
)
