# =============================================================================
# stdio_h_decls - AC_CHECK_DECLS_ONCE checks for fcloseall, getw, putw
# Only included when stdio_h is the main target (stdio_h test)
# =============================================================================

autoconf(
    name = "stdio_h_decls",
    checks = [
        # Define in config.h based on golden file expectations
        # HAVE_DECL_FCLOSEALL=0, HAVE_DECL_GETW=1, HAVE_DECL_PUTW=1 on macOS
        macros.AC_DEFINE(
            "HAVE_DECL_FCLOSEALL",
            condition = "_gl_cv_have_decl_fcloseall",
            if_false = "0",
            if_true = "1",
        ),
        macros.AC_DEFINE(
            "HAVE_DECL_GETW",
            condition = "_gl_cv_have_decl_getw",
            if_false = "0",
            if_true = "1",
        ),
        macros.AC_DEFINE(
            "HAVE_DECL_PUTW",
            condition = "_gl_cv_have_decl_putw",
            if_false = "0",
            if_true = "1",
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        ":stdio_h",  # Need the checks from stdio_h
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

