"""https://github.com/coreutils/gnulib/blob/635dbdcf501d52d2e42daf6b44261af9ce2dfe38/m4/stdio_h.m4"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

# gl_STDIO_H from stdio_h.m4 (lines 31-115)
# Check for stdio.h and related declarations.
autoconf(
    name = "stdio_h",
    checks = [
        # From gl_STDIO_H_EARLY: Define __USE_MINGW_ANSI_STDIO for MinGW - line 28
        # This makes printf/scanf use GNU-style format specifiers
        macros.AC_DEFINE("__USE_MINGW_ANSI_STDIO", "1"),

        # From gl_STDIO_H: Check which flavor of printf attribute matches inttypes macros
        # Lines 39-53: AC_CACHE_CHECK + AC_COMPILE_IFELSE
        # Sets GNULIB_PRINTF_ATTRIBUTE_FLAVOR_GNU=1 when compilation FAILS (gnu printf flavor)
        macros.AC_TRY_COMPILE(
            code = """\
#define __STDC_FORMAT_MACROS 1
#include <stdio.h>
#include <inttypes.h>
/* For non-mingw systems, compilation will trivially succeed.
   For mingw, compilation will succeed for older mingw (system
   printf, "I64d") and fail for newer mingw (gnu printf, "lld"). */
#if (defined _WIN32 && ! defined __CYGWIN__) && \
  (__GNUC__ > 4 || (__GNUC__ == 4 && __GNUC_MINOR__ >= 4))
extern char PRIdMAX_probe[sizeof PRIdMAX == sizeof "I64d" ? 1 : -1];
#endif
int main(void) { return 0; }
""",
            define = "_gl_cv_printf_attribute_flavor_system",
            language = "c",
        ),
        # Set GNULIB_PRINTF_ATTRIBUTE_FLAVOR_GNU when system flavor check fails
        macros.AC_DEFINE(
            "GNULIB_PRINTF_ATTRIBUTE_FLAVOR_GNU",
            condition = "_gl_cv_printf_attribute_flavor_system",
            if_false = "1",
        ),

        # AC_CHECK_DECLS_ONCE([fcloseall, getw, putw]) - lines 101-114
        # Check for these declarations
        # These are only defined in config.h when stdio_h is the main target (stdio_h test)
        # When used transitively (like by fprintf-gnu), they should be undefined
        # So we only set them as subst variables here, and define them in a separate target
        macros.AC_CHECK_DECL(
            "fcloseall",
            define = "_gl_cv_have_decl_fcloseall",
            headers = ["stdio.h"],
        ),
        macros.AC_CHECK_DECL(
            "getw",
            define = "_gl_cv_have_decl_getw",
            headers = ["stdio.h"],
        ),
        macros.AC_CHECK_DECL(
            "putw",
            define = "_gl_cv_have_decl_putw",
            headers = ["stdio.h"],
        ),
        # Set as subst variables
        macros.AC_SUBST(
            "HAVE_DECL_FCLOSEALL",
            condition = "_gl_cv_have_decl_fcloseall",
            if_false = "0",
            if_true = "1",
        ),
        macros.AC_SUBST(
            "HAVE_DECL_GETW",
            condition = "_gl_cv_have_decl_getw",
            if_false = "0",
            if_true = "1",
        ),
        macros.AC_SUBST(
            "HAVE_DECL_PUTW",
            condition = "_gl_cv_have_decl_putw",
            if_false = "0",
            if_true = "1",
        ),

        # Check for Microsoft-specific _snprintf declaration
        # On macOS, _snprintf is not available, so HAVE_DECL__SNPRINTF=0
        macros.AC_CHECK_DECL(
            "_snprintf",
            define = "_gl_cv_have_decl__snprintf",
            headers = ["stdio.h"],
        ),
        # Define HAVE_DECL__SNPRINTF in config.h (as 0 if not found)
        macros.AC_DEFINE(
            "HAVE_DECL__SNPRINTF",
            condition = "_gl_cv_have_decl__snprintf",
            if_false = "0",
            if_true = "1",
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # AC_REQUIRE([gl_STDIO_H_DEFAULTS]) - line 33
        ":defaults",
        # gl_NEXT_HEADERS([stdio.h]) - line 34
        "//gnulib/m4/include_next",
        # Note: AC_CHECK_INCLUDES_DEFAULT is added for test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

