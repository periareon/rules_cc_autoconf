"""https://github.com/coreutils/gnulib/blob/635dbdcf501d52d2e42daf6b44261af9ce2dfe38/m4/signal_h.m4"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

autoconf(
    name = "signal_h",
    checks = [
        # gl_SIGNAL_H checks for signal.h header
        macros.AC_CHECK_HEADER("signal.h"),

        # gl_CHECK_TYPE_SIGSET_T checks for sigset_t type
        macros.AC_CHECK_TYPE(
            "sigset_t",
            code = """\
#include <signal.h>
#include <sys/types.h>
int main(void) { sigset_t x; (void)x; return 0; }
""",
            define = "HAVE_SIGSET_T",
        ),

        # Check for volatile sig_atomic_t
        macros.AC_TRY_COMPILE(
            code = """\
#include <signal.h>
volatile sig_atomic_t x;
int main(void) { return 0; }
""",
            define = "_gl_have_volatile_sig_atomic_t",
            language = "c",
        ),
        macros.AC_SUBST(
            "HAVE_TYPE_VOLATILE_SIG_ATOMIC_T",
            condition = "_gl_have_volatile_sig_atomic_t",
            if_false = "0",
            if_true = "1",
        ),

        # Check for sighandler_t
        macros.AC_TRY_COMPILE(
            code = """\
#define _GNU_SOURCE 1
#include <signal.h>
sighandler_t x;
int main(void) { return 0; }
""",
            define = "_gl_have_sighandler_t",
            language = "c",
        ),
        macros.AC_SUBST(
            "HAVE_SIGHANDLER_T",
            condition = "_gl_have_sighandler_t",
            if_false = "0",
            if_true = "1",
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//gnulib/m4/include_next",  # gl_CHECK_NEXT_HEADERS
        "//gnulib/m4/extensions",  # Provides extension defines (_DARWIN_C_SOURCE, etc.)
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

autoconf(
    name = "defaults",
    checks = [
        # Module indicators - gl_SIGNAL_MODULE_INDICATOR
        macros.AC_SUBST("GNULIB_PTHREAD_SIGMASK", "0"),
        macros.AC_SUBST("GNULIB_RAISE", "0"),
        macros.AC_SUBST("GNULIB_SIG2STR", "0"),
        macros.AC_SUBST("GNULIB_SIGNAL_H_SIGPIPE", "0"),
        macros.AC_SUBST("GNULIB_SIGPROCMASK", "0"),
        macros.AC_SUBST("GNULIB_SIGACTION", "0"),
        # HAVE_* defaults - gl_SIGNAL_H_DEFAULTS
        macros.AC_SUBST("HAVE_POSIX_SIGNALBLOCKING", "1"),
        macros.AC_SUBST("HAVE_PTHREAD_SIGMASK", "1"),
        macros.AC_SUBST("HAVE_RAISE", "1"),
        macros.AC_SUBST("HAVE_SIG2STR", "1"),
        macros.AC_SUBST("HAVE_SIGINFO_T", "1"),
        macros.AC_SUBST("HAVE_SIGACTION", "1"),
        macros.AC_SUBST("HAVE_STR2SIG", "1"),
        macros.AC_SUBST("HAVE_STRUCT_SIGACTION_SA_SIGACTION", "1"),
        # REPLACE_* defaults
        macros.AC_SUBST("REPLACE_PTHREAD_SIGMASK", "0"),
        macros.AC_SUBST("REPLACE_RAISE", "0"),
    ],
    visibility = ["//visibility:public"],
)

autoconf(
    name = "with_defaults",
    checks = [],
    visibility = ["//visibility:public"],
    deps = [
        ":defaults",
        ":signal_h",
    ],
)
