"""https://github.com/coreutils/gnulib/blob/1039a5f2cee3cda1c11f64a5eb3a15b2e87cd2f0/m4/no-c++.m4"""

load("//autoconf:autoconf_toolchain.bzl", autoconf = "autoconf_cache")
load("//autoconf:checks.bzl", "checks")

autoconf(
    name = "no-c++",
    checks = [
        checks.AC_SUBST("NO_CXX", ""),
    ],
    visibility = ["//visibility:public"],
)
