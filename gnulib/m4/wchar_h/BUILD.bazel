autoconf(
    name = "wchar_h",
    checks = [
        # gl_WCHAR_H_INLINE_OK checks if wint_t type exists
        macros.AC_TRY_COMPILE(
            code = """#include <wchar.h>
int main(void) {
    wint_t x;
    (void)x;
    return 0;
}""",
            define = "HAVE_WINT_T",
        ),
        # Check for wcsdup declaration
        macros.AC_CHECK_DECL(
            "wcsdup",
            define = "HAVE_DECL_WCSDUP",
            headers = ["wchar.h"],
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//gnulib/m4/include_next",  # gl_CHECK_NEXT_HEADERS
        "//gnulib/m4/extensions",  # AC_REQUIRE([gl_USE_SYSTEM_EXTENSIONS]) - provides extension defines
