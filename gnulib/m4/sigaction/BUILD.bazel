"""https://github.com/coreutils/gnulib/blob/635dbdcf501d52d2e42daf6b44261af9ce2dfe38/m4/sigaction.m4"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

# gl_SIGACTION - lines 10-25
# Determine if sigaction interface is present
autoconf(
    name = "gl_SIGACTION",
    checks = [
        # AC_REQUIRE([gl_SIGNAL_H_DEFAULTS]) - line 12
        # Note: gl_SIGNAL_H_DEFAULTS is a _DEFAULTS function, so we ignore it per user's instruction

        # AC_CHECK_FUNCS_ONCE([sigaction]) - line 13
        macros.AC_CHECK_FUNC(
            "sigaction",
            define = "ac_cv_func_sigaction",
        ),

        # if test $ac_cv_func_sigaction = yes; then
        #   AC_CHECK_MEMBERS([struct sigaction.sa_sigaction], ...) - line 14-16
        #   if test $ac_cv_member_struct_sigaction_sa_sigaction = no; then
        #     HAVE_STRUCT_SIGACTION_SA_SIGACTION=0 - line 17-19
        #   fi
        # else
        #   HAVE_SIGACTION=0 - line 20-21
        # fi
        macros.AC_CHECK_MEMBER(
            "struct sigaction",
            "sa_sigaction",
            define = "ac_cv_member_struct_sigaction_sa_sigaction",
            headers = ["signal.h"],
            requires = ["ac_cv_func_sigaction==1"],
        ),

        # Set HAVE_SIGACTION as substitution variable
        macros.AC_SUBST(
            "HAVE_SIGACTION",
            condition = "ac_cv_func_sigaction",
            if_false = "0",
            if_true = "1",
        ),

        # Define HAVE_SIGACTION in config.h only if the function exists
        macros.AC_DEFINE(
            "HAVE_SIGACTION",
            condition = "ac_cv_func_sigaction",
            if_true = "1",
        ),

        # Set HAVE_STRUCT_SIGACTION_SA_SIGACTION as substitution variable
        macros.AC_SUBST(
            "HAVE_STRUCT_SIGACTION_SA_SIGACTION",
            condition = "ac_cv_member_struct_sigaction_sa_sigaction",
            if_false = "0",
        ),

        # Define HAVE_STRUCT_SIGACTION_SA_SIGACTION in config.h if the member exists
        macros.AC_DEFINE(
            "HAVE_STRUCT_SIGACTION_SA_SIGACTION",
            condition = "ac_cv_member_struct_sigaction_sa_sigaction",
            if_true = "1",
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # AC_REQUIRE([gl_SIGNAL_H_DEFAULTS]) - line 12
        # Note: gl_SIGNAL_H_DEFAULTS is a _DEFAULTS function, so we ignore it per user's instruction
        "//gnulib/m4/signal_h",
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

# gl_PREREQ_SIGACTION - lines 27-44
