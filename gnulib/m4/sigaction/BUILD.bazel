        # This is provided by gl_PREREQ_SIG_HANDLER_H dependency

        # AC_CHECK_FUNCS_ONCE([sigaltstack siginterrupt]) - line 34
        macros.AC_CHECK_FUNC(
            "sigaltstack",
            define = "ac_cv_func_sigaltstack",
        ),
        macros.AC_DEFINE(
            "HAVE_SIGALTSTACK",
