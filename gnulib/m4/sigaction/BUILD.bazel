        # if test $ac_cv_type_siginfo_t = no; then
        #   HAVE_SIGINFO_T=0 - line 39-41
        # fi
        macros.AC_SUBST(
            "HAVE_SIGINFO_T",
            condition = "ac_cv_type_siginfo_t",
            if_false = "0",
        ),

        # Define HAVE_SIGINFO_T in config.h if the type exists
        macros.AC_DEFINE(
            "HAVE_SIGINFO_T",
            condition = "ac_cv_type_siginfo_t",
            if_true = "1",
        ),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # AC_REQUIRE([gl_SIGNAL_H_DEFAULTS]) - line 30
        # Note: gl_SIGNAL_H_DEFAULTS is a _DEFAULTS function, so we ignore it per user's instruction
        "//gnulib/m4/signal_h",
        # AC_REQUIRE([AC_C_RESTRICT]) - line 31
        "//autoconf/macros/AC_C_RESTRICT",
        # AC_REQUIRE([AC_TYPE_UID_T]) - line 32
        "//autoconf/macros/AC_TYPE_UID_T",
        # AC_REQUIRE([gl_PREREQ_SIG_HANDLER_H]) - line 33
        ":gl_PREREQ_SIG_HANDLER_H",
        # For test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)

