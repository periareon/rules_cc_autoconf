# On Linux: uchar.h exists and char16_t works → passes → override=0
# On macOS: uchar.h doesn't exist → fails → override=1
autoconf(
    name = "gl_TYPE_CHAR16_T",
    checks = [
        checks.AC_TRY_COMPILE(
            name = "gl_cv_type_char16_t_works",
            code = """\
#ifdef __HAIKU__
#include <stdchar.h>
#endif
#include <uchar.h>
int verify[(char16_t)(-1) >= 0 && sizeof (char16_t) == sizeof (unsigned short) ? 1 : -1];
int main(void) { return 0; }
""",
        ),
        checks.AC_SUBST(
            "GNULIBHEADERS_OVERRIDE_CHAR16_T",
            condition = "gl_cv_type_char16_t_works",
            if_false = "1",
            if_true = "0",
        ),
    ],
    visibility = ["//visibility:public"],
)

