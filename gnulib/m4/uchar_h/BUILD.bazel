autoconf(
    name = "defaults",
    visibility = ["//visibility:public"],
    deps = [
        ":gl_UCHAR_H_REQUIRE_DEFAULTS",
    ],
)

autoconf(
    name = "uchar_h",
    visibility = ["//visibility:public"],
    deps = [
        ":gl_TYPE_CHAR16_T",
        ":gl_TYPE_CHAR32_T",
        ":gl_TYPE_CHAR8_T",
        ":gl_UCHAR_H",
        ":gl_UCHAR_MODULE_INDICATOR",
    ],
)
