"""https://github.com/coreutils/gnulib/blob/1039a5f2cee3cda1c11f64a5eb3a15b2e87cd2f0/m4/uchar_h.m4"""

load("//autoconf:autoconf_toolchain.bzl", autoconf = "autoconf_cache")
load("//autoconf:checks.bzl", "checks")
load("//gnulib:macros.bzl", gl_macros = "macros")

# gl_UCHAR_H - lines 13-116
autoconf(
    name = "gl_UCHAR_H",
    checks = [
        # gl_CHECK_NEXT_HEADERS([uchar.h]) also checks for the header
        checks.AC_CHECK_HEADER(
            "uchar.h",
            name = "ac_cv_header_uchar_h",
        ),
        # if test $ac_cv_header_uchar_h = yes; then HAVE_UCHAR_H=1 else HAVE_UCHAR_H=0 fi
        checks.AC_DEFINE(
            "HAVE_UCHAR_H",
            requires = ["ac_cv_header_uchar_h==1"],
        ),
        checks.AC_SUBST(
            "HAVE_UCHAR_H",
            condition = "ac_cv_header_uchar_h",
            if_false = "0",
            if_true = "1",
        ),
        # CXX_HAVE_UCHAR_H: check if C++ compiler has <uchar.h>
        # On Linux: yes (glibc). On macOS: yes (libc++).
        checks.AC_TRY_COMPILE(
            name = "gl_cv_cxx_have_uchar_h",
            code = """\
#include <uchar.h>
int main() { return 0; }
""",
            language = "cpp",
        ),
        checks.AC_SUBST(
            "CXX_HAVE_UCHAR_H",
            condition = "gl_cv_cxx_have_uchar_h",
            if_false = "0",
            if_true = "1",
        ),
        # CXX_HAS_CHAR8_TYPE: 0 on all platforms (char8_t is C++20, not yet available)
        checks.AC_SUBST("CXX_HAS_CHAR8_TYPE", "0"),
        # gl_STDINT_BITSIZEOF([wchar_t])
        checks.AC_COMPUTE_INT(
            "BITSIZEOF_WCHAR_T",
            "(int)(sizeof(wchar_t) * CHAR_BIT)",
            includes = [
                "#include <limits.h>",
                "#include <stddef.h>",
            ],
            subst = True,
        ),
        # if test $BITSIZEOF_WCHAR_T -lt 32; then SMALL_WCHAR_T=1
        checks.AC_SUBST(
            "SMALL_WCHAR_T",
            condition = "BITSIZEOF_WCHAR_T<32",
            if_false = "0",
            if_true = "1",
        ),
    ] + select({
        # CXX_HAS_UCHAR_TYPES: only checked when HAVE_UCHAR_H=0 (M4 line 71-91)
        # On Linux: HAVE_UCHAR_H=1 → check skipped → 0
        # On macOS: HAVE_UCHAR_H=0 → C++ has char16_t/char32_t → 1
        "@platforms//os:linux": [
            checks.AC_SUBST("CXX_HAS_UCHAR_TYPES", "0"),
        ],
        "//conditions:default": [
            checks.AC_SUBST("CXX_HAS_UCHAR_TYPES", "1"),
        ],
    }) + gl_macros.GL_CHECK_NEXT_HEADERS(["uchar.h"]),
    visibility = ["//visibility:public"],
    deps = [
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
        "//gnulib/m4/include_next",
    ],
)

# gl_TYPE_CHAR8_T - lines 118-140
# Checks if char8_t is correctly defined in <uchar.h>.
# On Linux: uchar.h exists but char8_t is not defined → fails → override=1
# On macOS: uchar.h doesn't exist in C mode → fails → override=1
autoconf(
    name = "gl_TYPE_CHAR8_T",
    checks = [
        checks.AC_TRY_COMPILE(
            name = "gl_cv_type_char8_t_works",
            code = """\
#ifdef __HAIKU__
#include <stdchar.h>
#endif
#include <uchar.h>
int verify[(char8_t)(-1) >= 0 && sizeof (char8_t) == sizeof (unsigned char) ? 1 : -1];
int main(void) { return 0; }
""",
        ),
        checks.AC_SUBST(
            "GNULIBHEADERS_OVERRIDE_CHAR8_T",
            condition = "gl_cv_type_char8_t_works",
            if_false = "1",
            if_true = "0",
        ),
    ],
    visibility = ["//visibility:public"],
)

# gl_TYPE_CHAR16_T - lines 143-168
