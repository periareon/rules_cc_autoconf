"""https://github.com/coreutils/gnulib/blob/635dbdcf501d52d2e42daf6b44261af9ce2dfe38/m4/posix_spawn_faction_addfchdir.m4"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

autoconf(
    name = "posix_spawn_faction_addfchdir",
    checks = [
        # HAVE_POSIX_SPAWN_FILE_ACTIONS_ADDFCHDIR is provided by spawn_h
        # Check for posix_spawn_file_actions_addfchdir_np (non-portable version)
        macros.AC_CHECK_FUNC(
            "posix_spawn_file_actions_addfchdir_np",
            code = "#include <spawn.h>",
            define = "HAVE_POSIX_SPAWN_FILE_ACTIONS_ADDFCHDIR_NP",
        ),
        # This function is not yet standardized, so always replace the system's implementation
        # REPLACE_POSIX_SPAWN_FILE_ACTIONS_ADDFCHDIR=1 is set by defaults if function exists
        # HAVE_POSIX_SPAWN_FILE_ACTIONS_ADDFCHDIR=0 is set by defaults if function doesn't exist
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//gnulib/m4/posix_spawn",  # AC_REQUIRE([gl_POSIX_SPAWN])
        "//gnulib/m4/spawn_h",  # AC_REQUIRE([gl_SPAWN_H_DEFAULTS]) - provides HAVE_POSIX_SPAWN_FILE_ACTIONS_ADDFCHDIR
    ],
)
