"""https://github.com/coreutils/gnulib/blob/1039a5f2cee3cda1c11f64a5eb3a15b2e87cd2f0/m4/memmove.m4"""

load("//autoconf:autoconf_toolchain.bzl", autoconf = "autoconf_cache")
load("//autoconf:checks.bzl", "checks")

autoconf(
    name = "memmove",
    checks = [
        # Equivalent to gl_FUNC_MEMMOVE macro from memmove.m4
        checks.AC_CHECK_FUNC(
            "memmove",
            define = "HAVE_MEMMOVE",
        ),
    ],
    visibility = ["//visibility:public"],
)
