"""https://github.com/coreutils/gnulib/blob/635dbdcf501d52d2e42daf6b44261af9ce2dfe38/m4/limits-h.m4"""

load("//autoconf:autoconf.bzl", "autoconf")
load("//autoconf:macros.bzl", "macros")

# gl_LIMITS_H from limits-h.m4 (lines 12-50)
autoconf(
    name = "limits-h",
    checks = [
        # gl_CHECK_NEXT_HEADERS([limits.h]) - line 15
        # This checks for limits.h header and sets NEXT_LIMITS_H and
        # NEXT_AS_FIRST_DIRECTIVE_LIMITS_H via include_next dependency
        macros.AC_CHECK_HEADER("limits.h", define = "HAVE_LIMITS_H"),
        
        # AC_CACHE_CHECK([whether limits.h has WORD_BIT, BOOL_WIDTH etc.],
        #   [gl_cv_header_limits_width], ...) - lines 17-30
        # Check if limits.h has WORD_BIT, BOOL_WIDTH, etc.
        macros.AC_TRY_COMPILE(
            code = """#ifndef __STDC_WANT_IEC_60559_BFP_EXT__
#define __STDC_WANT_IEC_60559_BFP_EXT__ 1
#endif
#include <limits.h>
long long llm = LLONG_MAX;
int wb = WORD_BIT;
int ullw = ULLONG_WIDTH;
int bw = BOOL_WIDTH;
int bm = BOOL_MAX;
int mblm = MB_LEN_MAX;""",
            define = "_gl_cv_header_limits_width",
            language = "c",
        ),
        
        # AC_CACHE_CHECK([whether limits.h has SSIZE_MAX],
        #   [gl_cv_header_limits_ssize_max], ...) - lines 32-42
        # Only checked if gl_cv_header_limits_width is yes
        # Check if limits.h has SSIZE_MAX
        macros.AC_TRY_COMPILE(
            code = """#include <limits.h>
#ifndef SSIZE_MAX
#error "SSIZE_MAX is not defined"
#endif""",
            define = "_gl_cv_header_limits_ssize_max",
            language = "c",
            requires = ["_gl_cv_header_limits_width=1"],
        ),
        
        # GL_GENERATE_LIMITS_H is set based on the checks above
        # If gl_cv_header_limits_width is yes and gl_cv_header_limits_ssize_max is yes,
        # then GL_GENERATE_LIMITS_H=false, otherwise GL_GENERATE_LIMITS_H=true
        # This is a substitution variable, not a define in config.h
        # Based on golden files, on macOS/Linux, GL_GENERATE_LIMITS_H is typically true
        # (limits.h needs to be generated/replaced)
        macros.AC_SUBST("GL_GENERATE_LIMITS_H", "true"),
    ],
    visibility = ["//visibility:public"],
    deps = [
        # gl_CHECK_NEXT_HEADERS([limits.h]) requires include_next
        "//gnulib/m4/include_next",
        
        # Note: AC_CHECK_INCLUDES_DEFAULT is added for test compatibility
        "//autoconf/macros/AC_CHECK_INCLUDES_DEFAULT",
    ],
)
