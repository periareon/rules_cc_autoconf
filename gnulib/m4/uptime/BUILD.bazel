"""https://github.com/coreutils/gnulib/blob/1039a5f2cee3cda1c11f64a5eb3a15b2e87cd2f0/m4/uptime.m4"""

load("//autoconf:autoconf_toolchain.bzl", autoconf = "autoconf_cache")
load("//autoconf:checks.bzl", "checks")

autoconf(
    name = "uptime",
    checks = select({
        # On Linux, /proc/uptime exists
        "@platforms//os:linux": [
            checks.AC_DEFINE("HAVE_PROC_UPTIME", 1),
        ],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)
