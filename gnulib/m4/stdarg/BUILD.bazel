"""https://github.com/coreutils/gnulib/blob/1039a5f2cee3cda1c11f64a5eb3a15b2e87cd2f0/m4/stdarg.m4"""

load("//autoconf:autoconf_toolchain.bzl", autoconf = "autoconf_cache")
load("//autoconf:checks.bzl", "checks")
load("//gnulib:macros.bzl", gl_checks = "checks")

autoconf(
    name = "gl_STDARG_H",
    checks = [
        checks.AC_TRY_COMPILE(
            name = "gl_cv_func_va_copy",
            code = """\
#include <stdarg.h>
#ifndef va_copy
void (*func) (va_list, va_list) = va_copy;
#endif
int main(void) { return 0; }
""",
        ),
        gl_checks.GL_NEXT_HEADER(
            "stdarg.h",
            name = "NEXT_STDARG_H",
        ),
        checks.AC_SUBST("NEXT_AS_FIRST_DIRECTIVE_STDARG_H", ""),
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//gnulib/m4/include_next",  # Required for INCLUDE_NEXT variables
    ],
)

autoconf(
    name = "stdarg",
    visibility = ["//visibility:public"],
    deps = [
        ":gl_STDARG_H",
    ],
)
